{
  "name": "kicad-mcp-chatgpt-app",
  "version": "0.2.0",
  "private": true,
  "description": "ChatGPT App for KiCad PCB project analysis and manufacturing readiness",
  "type": "module",
  "scripts": {
    "dev": "tsx watch -r dotenv/config src/server.ts",
    "build": "tsc",
    "start": "node --import dotenv/config dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
