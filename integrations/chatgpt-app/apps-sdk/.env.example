# KiCad MCP ChatGPT App Configuration
# Copy to .env and adjust values.

# Server port
PORT=8765

# Server bind host
HOST=0.0.0.0

# Path to kicad-mcp-pro executable (used for subprocess proxy)
# KICAD_MCP_CMD=kicad-mcp-pro

# Remote KiCad MCP URL (used when transport is streamable-http)
# KICAD_MCP_URL=http://localhost:8412/mcp

# Log level
# LOG_LEVEL=info
