{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "KiCad MCP Pro",
  "version": "3.8.0",
  "identifier": "dev.oaslananka.kicad-mcp-pro",
  "build": {
    "frontendDist": "frontend",
    "devUrl": "http://127.0.0.1:3334/ui",
    "beforeDevCommand": "uvx kicad-mcp-pro dashboard --host 127.0.0.1 --port 3334",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "url": "http://127.0.0.1:3334/ui",
        "title": "KiCad MCP Pro",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "title": "KiCad MCP Pro",
      "tooltip": "KiCad MCP Pro - Running"
    },
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "TAURI_SIGNING_PUBLIC_KEY_PLACEHOLDER",
      "endpoints": [
        "https://github.com/oaslananka/kicad-mcp/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    },
    "shell": {
      "open": true
    }
  }
}
