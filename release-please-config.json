{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "include-component-in-tag": true,
  "separate-pull-requests": true,
  "plugins": [
    {
      "type": "linked-versions",
      "groupName": "kicad-mcp-pro",
      "components": ["mcp-server", "mcp-npm"]
    }
  ],
  "packages": {
    ".": {
      "package-name": "kicad-mcp-pro",
      "tag-prefix": "mcp-server-v",
      "release-type": "python",
      "component": "mcp-server",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        {
          "type": "generic",
          "path": "src/kicad_mcp/__init__.py"
        },
        {
          "type": "json",
          "path": "server.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "server.json",
          "jsonpath": "$.packages[0].version"
        },
        {
          "type": "json",
          "path": "server.json",
          "jsonpath": "$.packages[1].version"
        },
        {
          "type": "json",
          "path": "server.json",
          "jsonpath": "$.packages[2].version"
        },
        {
          "type": "json",
          "path": "package.json",
          "jsonpath": "$.version"
        }
      ]
    },
    "packages/mcp-npm": {
      "package-name": "kicad-mcp-pro",
      "tag-prefix": "mcp-npm-v",
      "release-type": "node",
      "component": "mcp-npm",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/protocol-schemas": {
      "package-name": "@oaslananka/kicad-protocol-schemas",
      "tag-prefix": "proto-v",
      "release-type": "node",
      "component": "protocol-schemas",
      "changelog-path": "CHANGELOG.md"
    }
  }
}
