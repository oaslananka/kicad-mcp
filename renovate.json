{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "security:openssf-scorecard",
    "helpers:pinGitHubActionDigestsToSemver",
    ":configMigration",
    "group:allNonMajor"
  ],
  "timezone": "Europe/Istanbul",
  "labels": ["dependencies", "dependency-lifecycle"],
  "schedule": ["before 6am on monday"],
  "prHourlyLimit": 2,
  "prConcurrentLimit": 4,
  "minimumReleaseAge": "3 days",
  "enabledManagers": ["pep621", "github-actions", "dockerfile", "npm"],
  "rangeStrategy": "pin",
  "separateMajorMinor": true,
  "packageRules": [
    {
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true,
      "automerge": false,
      "labels": ["dependencies", "breaking-change", "risk:high"]
    },
    {
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true,
      "labels": ["risk:low"]
    },
    {
      "description": "MCP SDK minor/major: compatibility test required.",
      "matchPackageNames": ["mcp", "modelcontextprotocol"],
      "dependencyDashboardApproval": true,
      "automerge": false,
      "labels": ["compatibility", "risk:high"]
    },
    {
      "matchManagers": ["github-actions", "dockerfile", "docker-compose"],
      "pinDigests": true,
      "automerge": false,
      "labels": ["ci"]
    },
    {
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "matchPackageNames": ["typescript"],
      "minimumReleaseAge": "7 days",
      "automerge": false
    },
    {
      "matchPackageNames": ["/^@types\\//"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "prCreation": "immediate",
    "dependencyDashboardApproval": false,
    "labels": ["security"]
  },
  "osvVulnerabilityAlerts": true,
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on monday"],
    "automerge": true,
    "automergeType": "pr",
    "platformAutomerge": true
  }
}
